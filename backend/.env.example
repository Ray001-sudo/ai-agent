# ================================================================
#  TenderPro AI Agent — Environment Variables
#  Copy to .env and fill in values. NEVER commit .env to Git.
# ================================================================

# App
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:3000

# Auth — generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

# Admin Panel (SECRET — keep private)
# Dashboard is at /api/__<ADMIN_PATH_SECRET>/ — not guessable
ADMIN_PATH_SECRET=change_to_random_24_chars
ADMIN_SECRET_KEY=change_to_another_random_secret
ADMIN_IPS=your.public.ip.here
ADMIN_WHATSAPP_PHONE=+254700000000

# Database
# Local:  mongodb://localhost:27017/tenderpro
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/tenderpro
MONGODB_URI=mongodb://localhost:27017/tenderpro

# Redis
# Local:  redis://localhost:6379
# Render: set automatically as REDIS_URL env var
REDIS_URL=redis://localhost:6379

# ================================================================
#  AI PROVIDERS — Fallback chain: Anthropic → OpenAI → NVIDIA NIM
# ================================================================

# Primary: Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Secondary: OpenAI (vision + embeddings) — https://platform.openai.com
OPENAI_API_KEY=sk-proj-your-key-here

# Tertiary Fallback: NVIDIA NIM FREE tier
# Sign up FREE: https://build.nvidia.com
# Models: meta/llama-3.1-405b-instruct | 70b | 8b
# Free: 1000 credits/month — enough for fallback
NVIDIA_API_KEY=nvapi-your-key-here

# Vector DB: Pinecone — https://pinecone.io (free 5GB)
# Create index: dimension=3072, metric=cosine, name=tenderpro-vectors
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=tenderpro-vectors

# ================================================================
#  DISCOVERY — Neural Search (free tiers are sufficient)
# ================================================================

# Tavily — 1000 free credits/month — https://app.tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Exa Neural Search — 1000 free/month — https://exa.ai
EXA_API_KEY=your-exa-key-here

# Google Custom Search (optional)
GOOGLE_SEARCH_API_KEY=your-google-key
GOOGLE_SEARCH_CX=your-cx-id

# ================================================================
#  COMMUNICATIONS
# ================================================================

# WhatsApp via Twilio — https://console.twilio.com (sandbox FREE)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://your-app.onrender.com/api/whatsapp/webhook

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=TenderPro AI <noreply@tenderpro.ai>

# Google Calendar — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=https://your-app.onrender.com/api/calendar/callback

# Translation
DEEPL_API_KEY=your-deepl-api-key
GOOGLE_TRANSLATE_API_KEY=your-google-translate-key

# Currency — https://exchangerate-api.com (1500 free/month)
EXCHANGE_RATE_API_KEY=your-exchange-rate-key

# ================================================================
#  PAYMENTS
# ================================================================

# Stripe — https://dashboard.stripe.com (use sk_test_ for dev)
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# M-Pesa Daraja — https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your-key
MPESA_CONSUMER_SECRET=your-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-app.onrender.com/api/payments/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# ================================================================
#  AGENT SETTINGS
# ================================================================

SCRAPE_INTERVAL_HOURS=6
MAX_CONCURRENT_SCRAPERS=3
PUPPETEER_HEADLESS=true
PROXY_LIST=
LOCAL_STORAGE_PATH=./uploads
MAX_FILE_SIZE_MB=50
LOG_LEVEL=info
