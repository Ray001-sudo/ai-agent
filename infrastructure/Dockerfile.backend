FROM node:20-slim

# Install Playwright dependencies (Chromium for agentic browsing)
RUN apt-get update && apt-get install -y \
    curl wget ca-certificates \
    libglib2.0-0 libnss3 libnspr4 libdbus-1-3 \
    libatk1.0-0 libatk-bridge2.0-0 libcups2 \
    libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 \
    libxfixes3 libxrandr2 libgbm1 libasound2 \
    libpango-1.0-0 libcairo2 \
    fonts-liberation fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy and install backend deps
COPY backend/package.json ./backend/
RUN cd backend && npm install --production

# Install Playwright browsers
RUN cd backend && npx playwright install chromium --with-deps

# Copy source
COPY agent/ ./agent/
COPY backend/ ./backend/
COPY scripts/ ./scripts/

# Create required directories
RUN mkdir -p /app/backend/uploads /app/logs

# Non-root user for security
RUN groupadd -r tenderpro && useradd -r -g tenderpro tenderpro \
    && chown -R tenderpro:tenderpro /app
USER tenderpro

EXPOSE 5000
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

CMD ["node", "backend/server.js"]
